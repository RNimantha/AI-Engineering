   "source": [
    "import anyio\n",
    "from claude_agent_sdk import query\n",
    "\n",
    "async def main():\n",
    "    # Ask the agent a simple question\n",
    "    async for message in query(prompt=\"What is 2 + 2?\"):\n",
    "        print(f\"Agent: {message}\")\n",
    "\n",
    "anyio.run(main)"
   ]
