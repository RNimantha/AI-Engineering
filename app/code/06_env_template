# =============================================================================
# Claude Agent SDK — Environment Configuration Template
# =============================================================================
# Copy this file to the project root and rename it .env:
#
#   cp app/code/06_env_template .env
#
# Then fill in your actual values.  .env is git-ignored; never commit secrets.
# =============================================================================

# --- Database ----------------------------------------------------------------
# PyMySQL driver format: mysql+pymysql://user:password@host:port/database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/claude_agent_sdk

# --- Claude API --------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- FastAPI -----------------------------------------------------------------
DEBUG=True
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000

# --- CORS (comma-separated origins for the React dev server) -----------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Environment -------------------------------------------------------------
ENVIRONMENT=development
