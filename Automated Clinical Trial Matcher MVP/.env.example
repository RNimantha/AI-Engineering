# ─────────────────────────────────────────────
# Automated Clinical Trial Matcher MVP
# Environment Variables — copy to .env and fill in
# ─────────────────────────────────────────────

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Model used for all agents (override if needed)
CLAUDE_MODEL=claude-sonnet-4-6

# ClinicalTrials.gov API v2 base URL (no key needed — public API)
CLINICAL_TRIALS_API_BASE_URL=https://clinicaltrials.gov/api/v2

# Maximum number of trials the Searcher fetches (default: 20)
MAX_TRIALS=20

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
